# OIDC 环境变量配置示例
# 用于 Docker、Kubernetes 或其他容器部署

# 启用 OIDC 认证
OIDC_ENABLED=true

# OIDC 提供商名称（显示在登录按钮）
OIDC_PROVIDER_NAME=My Organization SSO

# OIDC 端点
OIDC_AUTH_ENDPOINT=https://your-oidc-server.com/oauth/authorize
OIDC_TOKEN_ENDPOINT=https://your-oidc-server.com/oauth/token
OIDC_USERINFO_ENDPOINT=https://your-oidc-server.com/oauth/userinfo
OIDC_JWKS_URI=https://your-oidc-server.com/oauth/discovery/keys

# 应用凭证
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_keep_this_safe

# 回调 URI（必须与 OIDC 提供商配置的重定向 URI 匹配）
OIDC_REDIRECT_URI=https://your-domain.com/admin/oidc-callback.php

# 请求权限范围
OIDC_SCOPES=openid,profile,email

# 新用户的默认权限级别
# 1 = 管理员 (完全权限)
# 2 = 上传者 (仅上传权限)
OIDC_DEFAULT_LEVEL=2

# 是否自动创建不存在的用户
OIDC_AUTO_CREATE_USER=false

# 用户白名单（逗号分隔）
# 留空表示允许所有通过 OIDC 认证的用户
OIDC_WHITELIST=user1,user2@example.com,admin@example.com

# SSL 验证（生产环境必须为 true）
OIDC_VERIFY_SSL=true

# API 连接超时（秒）
OIDC_TIMEOUT=30
